# SQLite file DB — zero setup required for local dev.
DATABASE_URL="file:./dev.db"

# Used to sign auth JWTs. Any long random string works for local dev;
# use a real secret manager in production.
JWT_SECRET="change-me"

# Server-side Gemini key (never exposed to the browser — this is the fix
# for the client-side-key issue flagged in the frontend's CHANGELOG).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
